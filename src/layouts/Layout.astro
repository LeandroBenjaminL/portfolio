---
const { title = 'Leandro Benjamin' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio de Leandro Benjamin — Data Engineer & Full-Stack Developer" />
    <title>{title}</title>

    <style>
      :root {
        --color-lilac: #ae8fdb;
        --color-mint: #6fdcbf;
        --color-rose: #dc849b;
        --color-sherbet: #fef8b4;
        --color-peach: #f2c3c0;
        --color-biscuit: #ad998a;
        --color-oat: #cbc1bd;
        --color-light: #f7f7f7;
        --color-light-fade: #eeebef;
        --color-mid: #cccccc;
        --color-dark: #404040;
        --color-dark-down: #303145;
        --color-bg: #eeebef;

        --font-base: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
        --max-width: 740px;
        --radius: 6px;
        --radius-lg: 10px;
      }

      /* ── Reset ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
      body {
        font-family: var(--font-base);
        font-size: 1.1rem;
        line-height: 1.75;
        color: var(--color-dark);
        background: var(--color-bg);
      }

      /* ── Skip to content ── */
      .skip-link {
        position: absolute;
        top: -100px;
        left: 1rem;
        background: var(--color-dark);
        color: white;
        padding: 0.5rem 1rem;
        z-index: 100;
        border-radius: var(--radius);
      }
      .skip-link:focus { top: 1rem; }

      /* ── Wrapper ── */
      .wrapper {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ── Nav ── */
      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 2.5rem 0 1.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .site-nav .home-link {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--color-dark);
        text-decoration: none;
      }
      .site-nav .home-link:hover { color: var(--color-lilac); }
      .site-nav .nav-links {
        display: flex;
        gap: 1.75rem;
        flex-wrap: wrap;
      }
      .site-nav .nav-links a {
        color: var(--color-dark);
        text-decoration: none;
        font-weight: 500;
        font-size: 1rem;
        transition: color 0.15s;
        background: linear-gradient(to right, var(--color-lilac), var(--color-lilac));
        background-size: 0 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 2px;
        transition: background-size 0.25s ease;
      }
      .site-nav .nav-links a:hover { background-size: 100% 2px; }

      /* ── Sections ── */
      .section { padding: 4.5rem 0; }

      /* ── Hero ── */
      .hero { padding: 2rem 0 4.5rem; }
      .hero .greeting {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--color-dark);
      }
      .hero .greeting .wave { font-size: 1.6rem; }
      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 1.75rem;
        max-width: 640px;
      }
      .hero h1 .highlight-link {
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-mint) 0%, var(--color-mint) 100%);
        background-size: 100% 0.35em;
        background-position: 0 0.85em;
        background-repeat: no-repeat;
        transition: background-size 0.2s ease;
      }
      .hero h1 .highlight-link:hover { background-size: 100% 0.5em; }
      .hero h1 .highlight-yellow {
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-sherbet) 0%, var(--color-sherbet) 100%);
        background-size: 100% 0.35em;
        background-position: 0 0.85em;
        background-repeat: no-repeat;
        transition: background-size 0.2s ease;
      }
      .hero h1 .highlight-yellow:hover { background-size: 100% 0.5em; }
      .hero .ctas {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.7rem 1.5rem;
        border-radius: 30px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.15s;
      }
      .btn-lilac {
        background: var(--color-lilac);
        color: #1a1a2e;
      }
      .btn-lilac:hover { background: #9b7dd0; transform: translateY(-1px); }
      .btn-outline {
        border: 2px solid var(--color-mid);
        color: var(--color-dark);
      }
      .btn-outline:hover { border-color: var(--color-dark); }

      /* ── Section headers ── */
      .section-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 2rem;
      }

      /* ── Cards ── */
      .card {
        background: var(--color-light);
        border-radius: var(--radius-lg);
        padding: 1.75rem;
        border: 1px solid transparent;
        transition: border-color 0.15s;
      }
      .card:hover { border-color: var(--color-oat); }
      .card + .card { margin-top: 1.25rem; }
      .card .card-badge {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        background: var(--color-lilac);
        color: #1a1a2e;
        padding: 0.2rem 0.7rem;
        border-radius: 4px;
        margin-bottom: 0.5rem;
      }
      .card .card-badge.mint { background: var(--color-mint); }
      .card .card-badge.rose { background: var(--color-rose); color: white; }
      .card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }
      .card h3 a {
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-mint), var(--color-mint));
        background-size: 0 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 2px;
        transition: background-size 0.25s ease;
      }
      .card h3 a:hover { background-size: 100% 2px; }
      .card .card-meta {
        font-size: 0.85rem;
        color: var(--color-biscuit);
        font-weight: 500;
        margin-bottom: 0.65rem;
      }
      .card p { color: var(--color-dark); font-size: 0.95rem; }
      .card .card-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--color-lilac);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        margin-top: 0.75rem;
      }
      .card .card-link:hover { text-decoration: underline; }

      /* ── Tags ── */
      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.75rem;
      }
      .tag {
        font-size: 0.78rem;
        font-weight: 500;
        padding: 0.25rem 0.7rem;
        border-radius: 4px;
        background: #e6e2ed;
        color: #5a4e7a;
      }

      /* ── Talk / Speaking-style cards ── */
      .talk-card {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
        padding: 1.25rem 0;
      }
      .talk-card + .talk-card { border-top: 1px solid var(--color-oat); }
      .talk-card .talk-type {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-biscuit);
        min-width: 80px;
        padding-top: 0.35rem;
      }
      .talk-card .talk-content h3 {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
      }
      .talk-card .talk-content p {
        font-size: 0.95rem;
        color: var(--color-dark);
        line-height: 1.6;
      }
      .talk-card .talk-content a {
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-lilac), var(--color-lilac));
        background-size: 0 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 2px;
        transition: background-size 0.25s ease;
      }
      .talk-card .talk-content a:hover { background-size: 100% 2px; }

      /* ── Contact ── */
      .contact-text {
        font-size: 1.1rem;
        line-height: 1.7;
        margin-bottom: 1.5rem;
      }
      .contact-text a {
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-lilac), var(--color-lilac));
        background-size: 0 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 2px;
        transition: background-size 0.25s ease;
      }
      .contact-text a:hover { background-size: 100% 2px; }
      .social-links {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .social-links a {
        font-weight: 600;
        font-size: 1.05rem;
        color: var(--color-dark);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-lilac), var(--color-lilac));
        background-size: 0 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 2px;
        transition: background-size 0.25s ease;
      }
      .social-links a:hover { background-size: 100% 2px; }

      /* ── Footer ── */
      .site-footer {
        padding: 3rem 0 2.5rem;
        font-size: 0.85rem;
        color: var(--color-biscuit);
      }
      .site-footer a {
        color: var(--color-biscuit);
        text-decoration: none;
        background: linear-gradient(to right, var(--color-biscuit), var(--color-biscuit));
        background-size: 0 1px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        padding-bottom: 1px;
        transition: background-size 0.25s ease;
      }
      .site-footer a:hover { background-size: 100% 1px; }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .site-nav { flex-direction: column; text-align: center; align-items: center; }
        .hero h1 { font-size: 2rem; }
        .section { padding: 3rem 0; }
        .talk-card { flex-direction: column; gap: 0.25rem; }
        .social-links { gap: 1.25rem; }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="wrapper">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/portfolio" class="home-link">LB</a>
        <div class="nav-links">
          <a href="#projects">proyectos</a>
          <a href="#labs">labs</a>
          <a href="#contact">contacto</a>
        </div>
      </nav>

      <main id="main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <p>&copy; 2026 Leandro Benjamin &middot; <a href="https://github.com/LeandroBenjaminL/portfolio">código fuente</a></p>
      </footer>
    </div>
  </body>
</html>
