---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leandro Benjamin — Portfolio">
  <!-- ═══ Hero ═══ -->
  <header class="hero">
    <p class="greeting">
      <span class="wave">👋</span> Hola, soy Leandro
    </p>
    <h1>
      Transformo
      <a href="#projects" class="highlight-link">datos</a>
      en pipelines, APIs en
      <a href="#projects" class="highlight-yellow">productos</a>
      y código en ecosistemas.
    </h1>
  </header>

  <!-- ═══ Proyectos ═══ -->
  <section id="projects" class="section">
    <h2 class="section-title">Proyectos.</h2>

    <!-- Datlas -->
    <article class="card">
      <span class="card-badge">destacado</span>
      <h3>
        <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener">Datlas</a>
      </h3>
      <p class="card-meta">FastAPI &middot; Pandas &middot; PostgreSQL &middot; Docker &middot; AWS &middot; Astro</p>
      <p>
        Plataforma de carga, limpieza y exploración de datasets. Detección automática de nulos,
        outliers y duplicados. Perfil estadístico completo y exportación a CSV, Excel, Parquet.
        Arquitectura serverless con AWS Lambda.
      </p>
      <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="card-link">
        Ver repositorio &rarr;
      </a>
    </article>

    <!-- LEND.AI -->
    <article class="card">
      <span class="card-badge mint">AI</span>
      <h3>
        <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener">LEND.AI</a>
      </h3>
      <p class="card-meta">Python &middot; MCP &middot; LLMs &middot; SQLite &middot; YAML</p>
      <p>
        Ecosistema de agentes de inteligencia artificial con routing inteligente de modelos,
        skills modulares y servidores MCP. Diseñado como plataforma extensible para amplificar
        el trabajo con modelos de lenguaje.
      </p>
      <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="card-link">
        Ver repositorio &rarr;
      </a>
    </article>

    <!-- Crypto Tracker -->
    <article class="card">
      <span class="card-badge rose">full-stack</span>
      <h3>
        <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener">Crypto Tracker</a>
      </h3>
      <p class="card-meta">Python &middot; APIs financieras &middot; React &middot; Node.js</p>
      <p>
        Rastreador de criptomonedas en tiempo real con datos de mercado, historial de precios
        y portfolio personal. Integración con APIs de exchanges y visualizaciones interactivas.
      </p>
      <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="card-link">
        Ver repositorio &rarr;
      </a>
    </article>

    <!-- Frontend Ecosystem -->
    <article class="card">
      <span class="card-badge">open source</span>
      <h3>
        <a href="https://github.com/LeandroBenjaminL/frontend-ecosystem" target="_blank" rel="noopener">Frontend Ecosystem</a>
      </h3>
      <p class="card-meta">Astro &middot; React &middot; TypeScript &middot; MCP &middot; Agentes AI</p>
      <p>
        Ecosistema de +30 agentes especializados para desarrollo frontend con inteligencia artificial.
        Skills de React, Astro, testing, performance, accesibilidad y CSS. Cada skill es un sub-agente
        efímero que ejecuta, reporta y libera contexto.
      </p>
      <a href="https://github.com/LeandroBenjaminL/frontend-ecosystem" target="_blank" rel="noopener" class="card-link">
        Ver repositorio &rarr;
      </a>
    </article>
  </section>

  <!-- ═══ Labs / Explorando ═══ -->
  <section id="labs" class="section">
    <h2 class="section-title">Explorando.</h2>

    <div class="talk-card">
      <span class="talk-type">data</span>
      <div class="talk-content">
        <h3><a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener">Data engineering pipelines</a></h3>
        <p>
          Diseño y construcción de pipelines ETL robustos con Python, FastAPI y PostgreSQL.
          De datos crudos a insights accionables, automatizando cada paso del proceso.
        </p>
      </div>
    </div>

    <div class="talk-card">
      <span class="talk-type">ai</span>
      <div class="talk-content">
        <h3><a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener">AI agent ecosystems</a></h3>
        <p>
          Arquitectura de agentes modulares con routing inteligente de modelos LLM.
          Explorando los límites de lo que los ecosistemas de agentes pueden lograr
          con MCP y skills especializadas.
        </p>
      </div>
    </div>

    <div class="talk-card">
      <span class="talk-type">frontend</span>
      <div class="talk-content">
        <h3><a href="https://github.com/LeandroBenjaminL/frontend-ecosystem" target="_blank" rel="noopener">Developer tooling</a></h3>
        <p>
          Creación de herramientas y ecosistemas que amplifican el desarrollo frontend.
          Skills, agentes y MCPs que supercargan cualquier AI coding agent con conocimiento
          profundo de React, Astro, testing y performance.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ Contacto ═══ -->
  <section id="contact" class="section">
    <h2 class="section-title">Charlemos.</h2>
    <p class="contact-text">
      Siempre abierto a colaborar en proyectos de datos, pipelines o ideas con AI.
      Escribime a
      <a href="mailto:leandrobenjaminl@hotmail.com">leandrobenjaminl@hotmail.com</a>
      o encontráme en:
    </p>
    <div class="social-links">
      <a href="https://github.com/LeandroBenjaminL" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/leandrobenjamin" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </section>
</Layout>
