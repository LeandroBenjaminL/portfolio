---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leandro Benjamin — Portfolio">
  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <header class="Hero">
    <div class="Hero__inner">
      <div class="Hero__content pad-around-lg">
        <p class="Hero__eyebrow font-cursive scramble">
          <span class="wave">👋</span> Hola, soy Leandro
        </p>
        <h1 class="Hero__heading">
          Transformo
          <a href="#projects" class="outline">datos</a>
          en pipelines, APIs en
          <a href="#projects" class="outline">productos</a>
          y c&oacute;digo en ecosistemas.
        </h1>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════ PROYECTOS ═══════════════════════ -->
  <section id="projects" class="Posts-intro pad-around-xlg">
    <div class="wrapper">
      <h2 class="Posts-intro__heading scramble">Proyectos.</h2>

      <!-- Datlas -->
      <article class="Browser">
        <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="Browser__heading underline">
          <h3 class="h5 underline__text">Datlas</h3>
        </a>
        <p>
          Plataforma de carga, limpieza y exploraci&oacute;n de datasets.
          Detecci&oacute;n autom&aacute;tica de nulos, outliers y duplicados.
          Perfil estad&iacute;stico completo. FastAPI + Pandas + PostgreSQL + AWS Lambda + Astro.
        </p>
        <footer class="Browser__footer">
          <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="source">Python &middot; FastAPI &middot; AWS</a>
          <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="read-more">Ver repositorio</a>
        </footer>
      </article>

      <!-- LEND.AI -->
      <article class="Browser">
        <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="Browser__heading underline">
          <h3 class="h5 underline__text">LEND.AI</h3>
        </a>
        <p>
          Ecosistema de agentes de IA con routing inteligente de modelos,
          skills modulares y servidores MCP. Dise&ntilde;ado como plataforma extensible
          para amplificar el trabajo con LLMs.
        </p>
        <footer class="Browser__footer">
          <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="source">MCP &middot; LLMs &middot; SQLite</a>
          <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="read-more">Ver repositorio</a>
        </footer>
      </article>

      <!-- Crypto Tracker -->
      <article class="Browser">
        <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="Browser__heading underline">
          <h3 class="h5 underline__text">Crypto Tracker</h3>
        </a>
        <p>
          Rastreador de criptomonedas en tiempo real con datos de mercado,
          historial de precios y portfolio personal. APIs de exchanges y visualizaciones interactivas.
        </p>
        <footer class="Browser__footer">
          <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="source">Python &middot; React &middot; Node.js</a>
          <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="read-more">Ver repositorio</a>
        </footer>
      </article>
    </div>
  </section>

  <!-- ═══════════════════════ LABS ═══════════════════════ -->
  <section id="labs" class="Speaking pad-around-xlg">
    <div class="wrapper">
      <div class="Speaking__intro">
        <div class="Speaking__text">
          <h2 class="Speaking__heading scramble">Explorando.</h2>
          <p>
            Del dato crudo al dashboard, de la idea al ecosistema.
            Me muevo entre el backend que procesa terabytes y el frontend
            que hace que todo se vea simple.
          </p>
          <p>
            Cada proyecto es una excusa para aprender algo nuevo:
            una API, un modelo de ML, un agente aut&oacute;nomo o una
            arquitectura serverless.
          </p>
          <a href="https://github.com/LeandroBenjaminL" target="_blank" rel="noopener" class="Speaking__link">
            Ver todos los repos &rarr;
          </a>
        </div>
        <figure class="Speaking__image">
          <div style="width:200px; height:200px; border-radius:8px; background:var(--color-lilac); display:flex; align-items:center; justify-content:center; font-size:4rem;">
            ⚡
          </div>
          <figcaption>data engineer</figcaption>
        </figure>
      </div>

      <div class="Speaking__talks">
        <article class="Card">
          <p class="Card__type scramble">data</p>
          <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="Card__link sf-flow underline">
            <h3 class="h4 underline__text">ETL pipelines &amp; data cleansing</h3>
            <p>
              Dise&ntilde;o y construcci&oacute;n de pipelines robustos con Python, FastAPI y PostgreSQL.
              Detecci&oacute;n autom&aacute;tica de anomal&iacute;as, normalizaci&oacute;n y exportaci&oacute;n multi-formato.
            </p>
          </a>
        </article>

        <article class="Card">
          <p class="Card__type scramble">ai</p>
          <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="Card__link sf-flow underline">
            <h3 class="h4 underline__text">AI agent ecosystems</h3>
            <p>
              Arquitectura de agentes modulares con routing inteligente de modelos LLM.
              Skills, MCPs y sub-agentes ef&iacute;meros que amplifican el trabajo con IA.
            </p>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CARRUSEL ═══════════════════════ -->
  <section id="projects-showcase" class="section carousel-section pad-around-xlg">
    <h2 class="Posts-intro__heading" style="text-align:center; margin-bottom:3rem;">Proyectos en foco.</h2>
    <div class="co-carousel-wrap">
      <div class="swiper co-carousel">
        <div class="swiper-wrapper">
          <!-- Datlas -->
          <div class="swiper-slide co-carousel__slide">
            <div class="proj-card">
              <div class="proj-card__icon">⚡</div>
              <div class="proj-card__body">
                <div class="text-mask"><span class="proj-card__label">Destacado</span></div>
                <div class="text-mask"><span class="proj-card__title">Datlas</span></div>
                <div class="text-mask"><span class="proj-card__desc">Carga, limpieza y exploraci&oacute;n de datasets. Detecci&oacute;n autom&aacute;tica de nulos y outliers.</span></div>
                <div class="proj-card__tags">
                  <span class="tag accent">Python</span>
                  <span class="tag teal">FastAPI</span>
                  <span class="tag">Pandas</span>
                  <span class="tag">PostgreSQL</span>
                  <span class="tag purple">Astro</span>
                  <span class="tag">Docker</span>
                  <span class="tag">AWS</span>
                </div>
                <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="proj-card__link">Ver repositorio &rarr;</a>
              </div>
            </div>
          </div>
          <!-- LEND.AI -->
          <div class="swiper-slide co-carousel__slide">
            <div class="proj-card">
              <div class="proj-card__icon">🧠</div>
              <div class="proj-card__body">
                <div class="text-mask"><span class="proj-card__label">AI Ecosystem</span></div>
                <div class="text-mask"><span class="proj-card__title">LEND.AI</span></div>
                <div class="text-mask"><span class="proj-card__desc">Ecosistema de agentes de IA con routing inteligente, skills modulares y servidores MCP.</span></div>
                <div class="proj-card__tags">
                  <span class="tag accent">Python</span>
                  <span class="tag teal">MCP</span>
                  <span class="tag purple">LLMs</span>
                  <span class="tag">SQLite</span>
                  <span class="tag">YAML</span>
                </div>
                <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="proj-card__link">Ver repositorio &rarr;</a>
              </div>
            </div>
          </div>
          <!-- Crypto Tracker -->
          <div class="swiper-slide co-carousel__slide">
            <div class="proj-card">
              <div class="proj-card__icon">📊</div>
              <div class="proj-card__body">
                <div class="text-mask"><span class="proj-card__label">Full-Stack</span></div>
                <div class="text-mask"><span class="proj-card__title">Crypto Tracker</span></div>
                <div class="text-mask"><span class="proj-card__desc">Rastreador de criptomonedas en tiempo real. APIs de mercado, historial y portfolio personal.</span></div>
                <div class="proj-card__tags">
                  <span class="tag accent">Python</span>
                  <span class="tag teal">APIs</span>
                  <span class="tag">React</span>
                  <span class="tag">Node.js</span>
                </div>
                <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="proj-card__link">Ver repositorio &rarr;</a>
              </div>
            </div>
          </div>
          <!-- Data Analyst Ecosystem -->
          <div class="swiper-slide co-carousel__slide">
            <div class="proj-card">
              <div class="proj-card__icon">🔬</div>
              <div class="proj-card__body">
                <div class="text-mask"><span class="proj-card__label">Open Source</span></div>
                <div class="text-mask"><span class="proj-card__title">Data Analyst Ecosystem</span></div>
                <div class="text-mask"><span class="proj-card__desc">Ecosistema de agentes AI para data science con routing inteligente de modelos LLM.</span></div>
                <div class="proj-card__tags">
                  <span class="tag accent">Python</span>
                  <span class="tag teal">MCP</span>
                  <span class="tag purple">LLMs</span>
                  <span class="tag">SQLite</span>
                  <span class="tag">YAML</span>
                </div>
                <a href="https://github.com/LeandroBenjaminL/data-analyst-ecosystem" target="_blank" rel="noopener" class="proj-card__link">Ver repositorio &rarr;</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="co-carousel__nav-buttons">
        <div class="co-carousel__nav-button prev"><span>Anterior</span></div>
        <div class="co-carousel__nav-button next"><span>Siguiente</span></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CONTACTO ═══════════════════════ -->
  <section id="contact" class="Contact pad-around-lg">
    <div class="wrapper">
      <h2 class="Contact__heading scramble">Charlemos.</h2>
      <div class="Contact__content">
        <p class="h6">
          Siempre abierto a colaborar en proyectos de datos, pipelines o ideas con IA.
        </p>
        <p class="h6">
          <a href="mailto:leandrobenjaminl@hotmail.com" style="color:var(--color-dark); font-weight:600;">leandrobenjaminl@hotmail.com</a>
        </p>
      </div>
      <div class="Contact__social">
        <a href="https://github.com/LeandroBenjaminL" target="_blank" rel="noopener" class="social-link">GitHub</a>
        <a href="https://linkedin.com/in/leandrobenjamin" target="_blank" rel="noopener" class="social-link">LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>
