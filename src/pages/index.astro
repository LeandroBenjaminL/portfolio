---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leandro Benjamin — Portfolio">
  <!-- Loading Screen -->
  <div class="loader-screen" id="loader">
    <div class="loader-content">
      <div class="loader-code-text">
        <div class="code-line" data-line="1">const portfolio = &#123;</div>
        <div class="code-line" data-line="2">  loading: true,</div>
        <div class="code-line" data-line="3">  status: 'initializing...'</div>
        <div class="code-line" data-line="4">&#125;;</div>
      </div>
      <div class="loader-spinner-wrapper"><div class="loader-spinner"></div></div>
      <div class="loader-progress-wrapper"><div class="loader-progress-bar"></div></div>
      <div class="loader-percentage" id="loaderPercent">0%</div>
    </div>
  </div>

  <!-- Nav -->
  <header class="main-header" id="header">
    <nav class="nav-container">
      <div class="nav-brand">
        <div class="brand-logo">
          <span class="logo-bracket">&lt;</span>
          <span class="logo-text">LB</span>
          <span class="logo-bracket">/&gt;</span>
        </div>
      </div>
      <div class="nav-menu" id="navMenu">
        <a href="#home" class="nav-link active" data-section="home"><i class="fas fa-home"></i><span class="nav-text">Home</span></a>
        <a href="#about" class="nav-link" data-section="about"><i class="fas fa-user"></i><span class="nav-text">About</span></a>
        <a href="#skills" class="nav-link" data-section="skills"><i class="fas fa-code"></i><span class="nav-text">Skills</span></a>
        <a href="#projects" class="nav-link" data-section="projects"><i class="fas fa-rocket"></i><span class="nav-text">Projects</span></a>
        <a href="#contact" class="nav-link" data-section="contact"><i class="fas fa-envelope"></i><span class="nav-text">Contact</span></a>
      </div>
      <button class="mobile-menu-toggle" id="menuToggle"><span></span><span></span><span></span></button>
    </nav>
  </header>

  <!-- ═══ HOME ═══ -->
  <section id="home" class="hero-section">
    <div class="hero-background">
      <div class="code-grid-bg"></div>
      <div class="floating-particles" id="particles"></div>
    </div>
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-greeting">
          <span class="greeting-text">Hola, soy</span>
          <span class="greeting-cursor">|</span>
        </div>
        <h1 class="hero-title">
          <span class="title-bracket">&lt;</span>
          <span class="title-name">Leandro Benjamin</span>
          <span class="title-bracket">/&gt;</span>
        </h1>
        <div class="hero-subtitle">
          <span class="subtitle-code">const</span>
          <span class="subtitle-role">role</span>
          <span class="subtitle-equals">=</span>
          <span class="subtitle-value">Data Engineer &amp; Full-Stack Developer</span>
          <span class="subtitle-semi">;</span>
        </div>
        <p class="hero-description">
          Transformo datos crudos en pipelines robustos, APIs en productos y c&oacute;digo en ecosistemas.
        </p>
        <div class="hero-buttons">
          <a href="#contact" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Contacto</a>
          <a href="#projects" class="btn btn-secondary"><i class="fas fa-rocket"></i> Proyectos</a>
        </div>
        <div class="hero-scroll"><span>Scroll Down</span><i class="fas fa-arrow-down"></i></div>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT ═══ -->
  <section id="about" class="about-section section">
    <div class="section-container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">
          <span class="title-bracket">&lt;</span>
          <span class="title-text">About Me</span>
          <span class="title-bracket">/&gt;</span>
        </h2>
        <div class="section-line"></div>
      </div>
      <div class="about-content">
        <div class="about-text">
          <p>
            Soy un Data Engineer y Full-Stack Developer. Mi lenguaje principal es Python — 
            lo uso para construir pipelines ETL, APIs con FastAPI, ecosistemas de agentes AI 
            y todo lo que haya en el medio. Tambi&eacute;n trabajo con PostgreSQL, Docker, AWS 
            y dise&ntilde;o interfaces modernas con React y Astro.
          </p>
          <p>
            Cada proyecto es una excusa para aprender algo nuevo: una arquitectura serverless, un agente
            aut&oacute;nomo o un dashboard que cuenta historias con datos.
          </p>
          <div class="about-stats">
            <div class="stat-item"><span class="stat-number" data-count="6">0</span><span class="stat-label">Proyectos</span></div>
            <div class="stat-item"><span class="stat-number" data-count="2">0</span><span class="stat-label">A&ntilde;os codeando</span></div>
            <div class="stat-item"><span class="stat-number" data-count="1">0</span><span class="stat-label">Ecosistemas AI</span></div>
          </div>
        </div>
        <div class="about-code">
          <div class="code-block">
            <div class="code-header"><span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span></div>
            <pre><code>
const developer = &#123;
  name: 'Leandro Benjamin',
  role: 'Data Engineer',
  skills: ['Python', 'FastAPI', 'PostgreSQL'],
  passion: 'Construir pipelines',
&#125;;
            </code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SKILLS ═══ -->
  <section id="skills" class="skills-section section">
    <div class="section-container">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">
          <span class="title-bracket">&lt;</span>
          <span class="title-text">Skills</span>
          <span class="title-bracket">/&gt;</span>
        </h2>
        <div class="section-line"></div>
      </div>
      <div class="skills-grid">
        <div class="skill-category">
          <h3 class="category-title">Backend &amp; Datos</h3>
          <div class="skill-items">
            <div class="skill-item" data-skill="Python" data-percent="95">
              <div class="skill-header"><span class="skill-name">Python</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="FastAPI" data-percent="85">
              <div class="skill-header"><span class="skill-name">FastAPI</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="Pandas" data-percent="80">
              <div class="skill-header"><span class="skill-name">Pandas / NumPy</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="PostgreSQL" data-percent="80">
              <div class="skill-header"><span class="skill-name">PostgreSQL / SQL</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
          </div>
        </div>
        <div class="skill-category">
          <h3 class="category-title">Frontend</h3>
          <div class="skill-items">
            <div class="skill-item" data-skill="Astro" data-percent="75">
              <div class="skill-header"><span class="skill-name">Astro</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="React" data-percent="75">
              <div class="skill-header"><span class="skill-name">React</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="TypeScript" data-percent="70">
              <div class="skill-header"><span class="skill-name">TypeScript</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
          </div>
        </div>
        <div class="skill-category">
          <h3 class="category-title">DevOps &amp; AI</h3>
          <div class="skill-items">
            <div class="skill-item" data-skill="Docker" data-percent="70">
              <div class="skill-header"><span class="skill-name">Docker</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="AWS" data-percent="65">
              <div class="skill-header"><span class="skill-name">AWS</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
            <div class="skill-item" data-skill="MCP" data-percent="80">
              <div class="skill-header"><span class="skill-name">MCP / LLMs</span><span class="skill-percent">0%</span></div>
              <div class="skill-bar"><div class="skill-progress"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ═══ -->
  <section id="projects" class="projects-section section">
    <div class="section-container">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">
          <span class="title-bracket">&lt;</span>
          <span class="title-text">Projects</span>
          <span class="title-bracket">/&gt;</span>
        </h2>
        <div class="section-line"></div>
      </div>
      <div class="projects-grid">
        <!-- Datlas -->
        <div class="project-card">
          <div class="project-image">
            <div class="project-icon">&#9889;</div>
          </div>
          <div class="project-content">
            <span class="project-category">Destacado</span>
            <h3 class="project-title">Datlas</h3>
            <p class="project-description">Plataforma de carga, limpieza y exploraci&oacute;n de datasets. Detecci&oacute;n autom&aacute;tica de nulos y outliers. FastAPI + Pandas + PostgreSQL + AWS Lambda + Astro.</p>
            <div class="project-tags">
              <span class="project-tag">Python</span><span class="project-tag">FastAPI</span><span class="project-tag">PostgreSQL</span><span class="project-tag">AWS</span><span class="project-tag">Docker</span><span class="project-tag">Astro</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="project-link"><i class="fab fa-github"></i> GitHub</a>
              <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="project-link"><i class="fas fa-external-link-alt"></i> Demo</a>
            </div>
          </div>
        </div>

        <!-- LEND.AI -->
        <div class="project-card">
          <div class="project-image">
            <div class="project-icon">&#129504;</div>
          </div>
          <div class="project-content">
            <span class="project-category">AI Ecosystem</span>
            <h3 class="project-title">LEND.AI</h3>
            <p class="project-description">Ecosistema de agentes de IA con routing inteligente de modelos, skills modulares y servidores MCP. Dise&ntilde;ado como plataforma extensible para amplificar el trabajo con LLMs.</p>
            <div class="project-tags">
              <span class="project-tag">Python</span><span class="project-tag">MCP</span><span class="project-tag">LLMs</span><span class="project-tag">SQLite</span><span class="project-tag">YAML</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="project-link"><i class="fab fa-github"></i> GitHub</a>
              <a href="https://github.com/LeandroBenjaminL/lend-ai" target="_blank" rel="noopener" class="project-link"><i class="fas fa-external-link-alt"></i> Demo</a>
            </div>
          </div>
        </div>

        <!-- Crypto Tracker -->
        <div class="project-card">
          <div class="project-image">
            <div class="project-icon">&#128202;</div>
          </div>
          <div class="project-content">
            <span class="project-category">Full-Stack</span>
            <h3 class="project-title">Crypto Tracker</h3>
            <p class="project-description">Rastreador de criptomonedas en tiempo real con APIs de mercado, historial de precios y portfolio personal. Python + React + Node.js.</p>
            <div class="project-tags">
              <span class="project-tag">Python</span><span class="project-tag">React</span><span class="project-tag">Node.js</span><span class="project-tag">APIs</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="project-link"><i class="fab fa-github"></i> GitHub</a>
              <a href="https://github.com/LeandroBenjaminL/crypto-tracker" target="_blank" rel="noopener" class="project-link"><i class="fas fa-external-link-alt"></i> Demo</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section id="contact" class="contact-section section">
    <div class="section-container">
      <div class="section-header">
        <span class="section-number">04</span>
        <h2 class="section-title">
          <span class="title-bracket">&lt;</span>
          <span class="title-text">Contact</span>
          <span class="title-bracket">/&gt;</span>
        </h2>
        <div class="section-line"></div>
      </div>
      <div class="contact-content" style="display:flex; flex-direction:column; align-items:flex-end;">
        <form id="contactForm" class="contact-form" style="width:100%; max-width:580px;">
          <div class="form-group"><input type="text" placeholder="Nombre" required /></div>
          <div class="form-group"><input type="email" placeholder="Email" required /></div>
          <div class="form-group"><textarea placeholder="Mensaje" rows="4" required></textarea></div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Enviar</button>
        </form>
        <div style="margin-top:2rem; width:100%; max-width:580px;">
          <p style="margin-bottom:0.75rem; color:var(--text-secondary); font-size:0.92rem; line-height:1.6;">
            Siempre abierto a colaborar en proyectos de datos, pipelines o ideas con IA.
          </p>
          <div class="contact-item"><i class="fas fa-envelope"></i><span>leandrobenjaminnn@gmail.com</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="main-footer">
    <div class="footer-content">
      <p>Leandro Benjamin &middot; Data Engineer</p>
    </div>
  </footer>
</Layout>
